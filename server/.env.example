# Bridge server
PORT=3456
# CMUX_SOCKET_PATH=
# CMUX_BIN_PATH=

# Cloudflare Tunnel
# Set to true to expose this server through Cloudflare Tunnel.
# - With CLOUDFLARE_TUNNEL_TOKEN: runs the named tunnel matching that token
#   (configure the route in the Cloudflare Zero Trust dashboard).
# - Without a token: starts a free Quick Tunnel and prints a *.trycloudflare.com URL.
# Requires the `cloudflared` binary to be installed and on PATH (override with CLOUDFLARED_BIN).
CLOUDFLARE_TUNNEL_ENABLED=false
CLOUDFLARE_TUNNEL_TOKEN=
# CLOUDFLARED_BIN=cloudflared

# ngrok
# Set to true to expose this server through ngrok.
# - With NGROK_AUTHTOKEN: uses that token (overrides any system config).
# - Without a token: relies on the authtoken already configured via
#   `ngrok config add-authtoken <token>` (free tier still requires a free account).
# Requires the `ngrok` binary to be installed and on PATH (override with NGROK_BIN).
NGROK_ENABLED=false
NGROK_AUTHTOKEN=
# NGROK_BIN=ngrok
